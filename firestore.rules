rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reusable validation
    function isSignedIn() { return request.auth != null; }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidArticle() {
      return incoming().keys().hasAll(['title', 'author', 'date', 'status'])
        && incoming().title is string && incoming().title.size() > 0
        && incoming().status in ['published', 'archived']
        && incoming().author is string
        && incoming().date is string;
    }

    match /articles/{articleId} {
      allow read, write: if true;
    }

    match /gallery/{imageId} {
      allow read, write: if true;
    }
  }
}
